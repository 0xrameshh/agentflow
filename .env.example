# At least one provider is required
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# openai | anthropic
AGENTFLOW_MODEL_PROVIDER=openai
AGENTFLOW_MODEL_NAME=gpt-4o-mini

# chroma (default) | keyword
AGENTFLOW_RETRIEVER=chroma

# API port (use 8081 if 8080 is taken by another app, e.g. goproxy)
AGENTFLOW_PORT=8081

# Documents directory (the knowledge base)
AGENTFLOW_DOCS_DIR=data/knowledge

# CORS origins for Next.js web UI (comma-separated)
AGENTFLOW_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional display name for the UI
AGENTFLOW_KB_NAME=Knowledge Copilot
